<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example1.practice1.mapper.BoardMapper">

<!-- 게시글 등록 -->
<insert id="insertBoard" parameterType="com.example1.practice1.domain.BoardVO">
INSERT	INTO	pro_board
			(BNO, 		SUBJECT, 	CONTENT, 	WRITER, 	REG_DATE)
	VALUES	(#{bno},	#{subject},	#{content},	#{writer},	now() )

</insert>

<!-- 게시글 목록보기 
<select id="boardList" resultType="com.example1.practice1.domain.BoardVO">
SELECT *
FROM pro_board
ORDER BY bno DESC

</select>-->
<!-- 게시글 페이징 -->
<select id="boardList" resultType="com.example1.practice1.domain.BoardVO" parameterType="com.example1.practice1.domain.Criteria">
SELECT bno, 
		        SUBJECT, 
		        CONTENT,
		        WRITER, 
		        REG_DATE,
		        HIT
		 FROM ( 
		        SELECT BNO, 
		               SUBJECT, 
		               CONTENT, 
		               WRITER, 
		               REG_DATE, 
		               HIT,
		               ROW_NUMBER() OVER(ORDER BY BNO DESC) AS RNUM
		         FROM pro_board
		         WHERE 1=1 
		         	<include refid="search"></include>
		                       ) MP
		WHERE RNUM BETWEEN #{rowStart} AND #{rowEnd}
		ORDER BY BNO DESC
	</select>

<!-- 게시글페이지 개수 -->
<select id="listCount" parameterType="com.example1.practice1.domain.SearchCriteria" resultType="int">

SELECT COUNT(bno)
FROM pro_board
WHERE bno > 0  <!-- 참이라는 의미,bno가 0이상인 데이터들을 모두 조회한다는 의미  -->
<include refid="search"></include>

</select>
<!-- 검색기능 -->
<sql id="search">
		<if test="searchType != null">
			<if test="searchType == 's'.toString()">AND SUBJECT LIKE CONCAT('%',#{keyword},'%')</if>
			<if test="searchType == 'c'.toString()">AND CONTENT LIKE CONCAT('%',#{keyword},'%')</if>
			<if test="searchType == 'w'.toString()">AND WRITER LIKE CONCAT('%',#{keyword},'%')</if>
			<if test="searchType == 'sc'.toString()">AND (SUBJECT LIKE CONCAT('%',#{keyword},'%')) or (CONTENT LIKE CONCAT('%',#{keyword},'%'))</if>
		</if>
	</sql>

<!-- 게시글 상세보기 -->
<select id="detail" parameterType="int" resultType="com.example1.practice1.domain.BoardVO">
SELECT * 
FROM pro_board
WHERE bno = ${bno}

</select>



<!-- bno에 해당하는 게시글의 정보를 수정한다. -->
<update id="update" parameterType="com.example1.practice1.domain.BoardVO">
UPDATE	pro_board
SET		<if test="subject != null and subject !=''">subject = #{subject}</if>
		<if test="subject != null and subject !='' and content != null and content !=''"> , </if> <!-- ,의 의미는 여러개 넘어와야할때 사용. -->
		<if test="content != null and content !=''">content = #{content}</if>
WHERE	bno	= #{bno}
</update>

<!-- 게시글 삭제 -->
<delete id="delete">
DELETE FROM
pro_board
WHERE bno = #{bno}

</delete>

<!-- 게시글 조회수 -->
<update id="boardHit" parameterType="int">
	UPDATE pro_board
	SET hit = hit + 1
	WHERE bno = #{bno}
</update>
</mapper>